<Window x:Class="TaskbarBadge.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TaskbarBadge Settings"
        Width="460"
        Height="680"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="Label" />
            <TextBox x:Name="LabelBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" />

            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="Badge color" />
            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                <Button x:Name="BackgroundColorButton"
                        Height="30"
                        HorizontalContentAlignment="Center"
                        Click="BackgroundColorButton_Click"
                        Content="Choose..." />
                <WrapPanel x:Name="BackgroundPresetPanel" Margin="0,4,0,0" />
            </StackPanel>

            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="Text color" />
            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,10">
                <Button x:Name="TextColorButton"
                        Height="30"
                        HorizontalContentAlignment="Center"
                        Click="TextColorButton_Click"
                        Content="Choose..." />
                <WrapPanel x:Name="TextPresetPanel" Margin="0,4,0,0" />
            </StackPanel>

            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="Width" />
            <TextBox x:Name="WidthBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,10" />

            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="Height" />
            <TextBox x:Name="HeightBox" Grid.Row="4" Grid.Column="1" Margin="0,0,0,10" />

            <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="Font size" />
            <TextBox x:Name="FontSizeBox" Grid.Row="5" Grid.Column="1" Margin="0,0,0,10" />

            <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="Opacity" />
            <TextBox x:Name="OpacityBox" Grid.Row="6" Grid.Column="1" Margin="0,0,0,10" />

            <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="Anchor" />
            <ComboBox x:Name="AnchorBox" Grid.Row="7" Grid.Column="1" Margin="0,0,0,10" />

            <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="Along-taskbar offset" />
            <TextBox x:Name="AlongOffsetBox" Grid.Row="8" Grid.Column="1" Margin="0,0,0,10" />

            <TextBlock Grid.Row="9" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="Cross-taskbar offset" />
            <TextBox x:Name="CrossOffsetBox" Grid.Row="9" Grid.Column="1" Margin="0,0,0,10" />

            <StackPanel Grid.Row="10" Grid.ColumnSpan="2">
                <TextBlock Margin="0,8,0,4"
                           FontWeight="SemiBold"
                           Text="The tray icon is always shown. The overlay badge is optional and can be dragged when unlocked." />
                <CheckBox x:Name="ShowBadgeBox" Margin="0,4" Content="Show overlay badge" />
                <CheckBox x:Name="LockOverlayBox" Margin="0,4" Content="Lock overlay position" />
                <CheckBox x:Name="RunAtStartupBox" Margin="0,4" Content="Start with Windows" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Width="90" Margin="0,12,8,0" Click="Save_Click" Content="Save" IsDefault="True" />
            <Button Width="90" Margin="0,12,0,0" Click="Cancel_Click" Content="Cancel" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
